
<!DOCTYPE html>
<html>
<head>
    <title>HTML Formatting Tags Demo</title>
</head>
<body>

    <!-- Headings -->
    <h1>Heading 1</h1>
    <h2>Heading 2</h2>
    <h3>Heading 3</h3>
    <h4>Heading 4</h4>
    <h5>Heading 5</h5>
    <h6>Heading 6</h6>

    <!-- Paragraph -->
    <p>
        This is a paragraph demonstrating various HTML formatting tags.
    </p>

    <!-- Bold -->
    <p>
        <b>This text is bold.</b>
    </p>

    <!-- Italic -->
    <p>
        <i>This text is italic.</i>
    </p>

    <!-- Underline -->
    <p>
        <u>This text is underlined.</u>
    </p>

    <!-- Superscript -->
    <p>
        (a + b)<sup>2</sup> = a<sup>2</sup> + 2ab + b<sup>2</sup>
    </p>

    <!-- Subscript -->
    <p>
        Chemical formula of water: H<sub>2</sub>O
    </p>

</body>
</html>
